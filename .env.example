# ── Phi-nance environment template ───────────────────────────────────────────
# Copy to .env and fill in your values.
# The .env file is gitignored — NEVER commit real keys.
#
# Usage:
#   cp .env.example .env
#   # edit .env with real credentials
#   docker compose up --build   (or)   python -m streamlit run ...
# ─────────────────────────────────────────────────────────────────────────────

# ── Data vendors ──────────────────────────────────────────────────────────────
# Alpha Vantage (free tier: 25 requests/day)
# Sign up: https://www.alphavantage.co/support/#api-key
AV_API_KEY=your_alpha_vantage_key_here
AV_MCP_TOKEN=your_av_mcp_token_here

# MarketDataApp (options chain snapshots)
# Sign up: https://marketdata.app/
MARKETDATAAPP_API_TOKEN=your_marketdataapp_token_here

# ── Alpaca Broker (paper + live trading) ─────────────────────────────────────
# Sign up: https://alpaca.markets/
# Paper trading base URL: https://paper-api.alpaca.markets
# Live trading base URL:  https://api.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_FEED=iex        # iex (free) | sip (paid)

# ── IBKR (Interactive Brokers) ────────────────────────────────────────────────
# Requires TWS or IB Gateway running locally (or in a container).
# TWS paper port: 7497 | live: 7496
# IB Gateway paper port: 4002 | live: 4001
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=DU000000   # paper account number

# ── Optuna / PhiAI tuning ─────────────────────────────────────────────────────
# Set OPTUNA_STORAGE to persist study results across runs.
# Default: in-memory (no persistence).
# SQLite example: sqlite:///runs/optuna.db
# PostgreSQL:     postgresql://user:pass@db:5432/phinance
OPTUNA_STORAGE=
PHIAI_N_TRIALS=50       # Bayesian trials per indicator (default 50)
PHIAI_N_JOBS=4          # parallel Optuna workers (default 4)

# ── Runtime ───────────────────────────────────────────────────────────────────
DATA_CACHE_ROOT=./data_cache
PHINANCE_LOG_LEVEL=INFO

# ── DigitalOcean (VPS control) ────────────────────────────────────────────────
DIGITALOCEAN_TOKEN=your_dop_v1_token_here
